---
import { navLinks, waDefault } from '../data/content';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header class="fixed top-0 inset-x-0 z-50 bg-cream/90 backdrop-blur-md border-b border-bordercol">
  <div class="max-w-[1180px] mx-auto px-6 md:px-8 py-4 flex items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-3">
      <svg width="22" height="28" viewBox="0 0 24 30" fill="none" stroke="#6B2737" stroke-width="1" stroke-linecap="round">
        <path d="M12 29 C12 20 12 11 12 2"></path>
        <path d="M12 22 C7 20.5 5 16.5 5 12.5"></path>
        <path d="M12 22 C17 20.5 19 16.5 19 12.5"></path>
        <path d="M12 15 C8.5 13.8 6.5 11 6.5 8"></path>
        <path d="M12 15 C15.5 13.8 17.5 11 17.5 8"></path>
        <circle cx="12" cy="2.6" r="1.7" fill="#6B2737" stroke="none"></circle>
      </svg>
      <span class="font-serif text-[23px] text-dark leading-none tracking-[.01em]">
        Éclat<span class="block font-sans text-[8.5px] tracking-[.34em] text-[#9A7F84] uppercase mt-0.5">Estética Avançada</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-7">
      {navLinks.map((link) => (
        <a href={link.href} class="text-[13.5px] tracking-[.02em] text-[#5A4747]">
          {link.label}
          <div class="h-[1.5px] bg-primary mt-1 transition-opacity duration-200" style={{ opacity: isActive(link.href) ? 1 : 0 }}></div>
        </a>
      ))}
      <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-5 py-2.5 rounded-full text-[13px] font-medium tracking-[.02em] hover:bg-dark transition-colors">
        Agende sua avaliação
      </a>
    </nav>

    <button id="menu-toggle" aria-label="Abrir menu" class="lg:hidden flex flex-col gap-1.5 p-2">
      <span class="w-6 h-[1.5px] bg-dark"></span>
      <span class="w-6 h-[1.5px] bg-dark"></span>
      <span class="w-6 h-[1.5px] bg-dark"></span>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden lg:hidden border-t border-bordercol bg-cream">
    <div class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map((link) => (
        <a href={link.href} class:list={["text-[14px]", isActive(link.href) ? "text-primary font-medium" : "text-[#5A4747]"]}>
          {link.label}
        </a>
      ))}
      <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-5 py-2.5 rounded-full text-[13.5px] font-medium text-center">
        Agende sua avaliação
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
