---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Rodape from '../components/Rodape.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { site, img } from '../data/content';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
}

const { title, description, path = '/', ogImage = img.faceHero } = Astro.props;
const canonical = `https://${site.dominio}${path}`;
const ogImage1200 = ogImage.replace('w=1600', 'w=1200');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: site.nome,
  description: `${site.nicho} em ${site.cidade}/${site.estado} com atendimento personalizado e critério médico.`,
  url: `https://${site.dominio}`,
  telephone: `+55${site.whatsapp}`,
  email: site.email,
  foundingDate: site.anoFundacao,
  priceRange: '$$',
  areaServed: site.cidade,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Beira Mar, 720, Praia Grande',
    addressLocality: site.cidade,
    addressRegion: site.estado,
    postalCode: '95560-000',
    addressCountry: 'BR',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '09:00', closes: '19:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '09:00', closes: '13:00' },
  ],
  sameAs: [`https://instagram.com/${site.instagram}`],
};
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.nome} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage1200} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage1200} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preload" as="image" href={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Work+Sans:wght@300;400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    </noscript>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </head>
  <body class="bg-cream text-ink font-sans">
    <Navbar />
    <main class="pt-[73px]">
      <slot />
    </main>
    <Rodape />
    <WhatsAppButton />
    <script>
      import AOS from 'aos';
      import 'aos/dist/aos.css';
      AOS.init({ duration: 700, once: true, offset: 80 });
    </script>
  </body>
</html>
