---
import Layout from '../layouts/Layout.astro';
import { seo, waDefault, img } from '../data/content';
---
<Layout title={seo.campanha.title} description={seo.campanha.description} path="/campanha" ogImage={img.lipsWide}>

  <section class="max-w-[760px] mx-auto px-6 md:px-8 py-28 text-center" data-aos="fade-up">
    <svg width="26" height="32" viewBox="0 0 24 30" fill="none" stroke="#C99CA6" stroke-width="1" stroke-linecap="round" class="mx-auto mb-6">
      <path d="M12 29 C12 20 12 11 12 2"></path><path d="M12 22 C7 20.5 5 16.5 5 12.5"></path><path d="M12 22 C17 20.5 19 16.5 19 12.5"></path><path d="M12 15 C8.5 13.8 6.5 11 6.5 8"></path><path d="M12 15 C15.5 13.8 17.5 11 17.5 8"></path><circle cx="12" cy="2.6" r="1.7" fill="#C99CA6" stroke="none"></circle>
    </svg>
    <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Landing de campanha</span>
    <h1 class="font-serif text-3xl md:text-[42px] text-dark mt-4 mb-5 leading-[1.15]">Campanha de preenchimento labial</h1>
    <p class="text-base leading-[1.75] text-muted mb-9">Esta é a página reservada para a landing de campanha, onde a oferta e as condições serão apresentadas. O conteúdo completo será construído em uma etapa dedicada.</p>
    <div class="inline-flex gap-5 flex-wrap justify-center">
      <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-8 py-3.5 rounded-full text-[14.5px] font-medium hover:bg-dark transition-colors">Falar pelo WhatsApp</a>
      <a href="/" class="text-[14.5px] text-primary border-b border-[#D9AEB6] pb-1 self-center">Voltar para a Home</a>
    </div>
  </section>

</Layout>
