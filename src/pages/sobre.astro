---
import Layout from '../layouts/Layout.astro';
import { seo, pilares, team, img } from '../data/content';
---
<Layout title={seo.sobre.title} description={seo.sobre.description} path="/sobre" ogImage={img.clinic}>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 pt-20 pb-10">
    <div class="text-center max-w-[720px] mx-auto" data-aos="fade-up">
      <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Sobre a Éclat</span>
      <h1 class="font-serif text-4xl md:text-[46px] text-dark mt-4 mb-5 leading-[1.15]">Estética avançada com critério e delicadeza</h1>
      <p class="text-[17px] leading-[1.75] text-muted">
        A Éclat nasceu do desejo de oferecer, em Torres, um espaço onde a estética avançada caminha lado a lado com a segurança médica. Aqui, cada procedimento parte de uma avaliação individual — porque nenhum rosto é igual ao outro.
      </p>
    </div>
  </section>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 py-5">
    <div class="h-[280px] md:h-[420px] rounded-[20px] overflow-hidden" data-aos="fade-left">
      <img src={img.clinic} width="1600" height="420" loading="lazy" alt="Ambiente da clínica Éclat — clean e sofisticado" class="w-full h-full object-cover" />
    </div>
  </section>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-9">
      {pilares.map((p, i) => (
        <div data-aos="zoom-in" data-aos-delay={i * 80}>
          <h3 class="font-serif font-medium text-xl text-dark mb-3">{p.title}</h3>
          <p class="text-[14.5px] leading-relaxed text-softmuted">{p.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-blush">
    <div class="max-w-[1180px] mx-auto px-6 md:px-8 py-24">
      <div class="text-center mb-14" data-aos="fade-up">
        <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Equipe médica</span>
        <h2 class="font-serif text-2xl md:text-4xl text-dark mt-3">Quem cuida de você</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-7">
        {team.map((m, i) => (
          <div class="bg-white border border-bordercol rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay={i * 80}>
            <div class="h-[300px]">
              <img src={m.img} width="400" height="300" loading="lazy" alt={`Retrato de ${m.name}`} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <h3 class="font-serif font-medium text-xl text-dark mb-1">{m.name}</h3>
              <p class="text-[13px] text-primary tracking-[.04em] mb-2">{m.role}</p>
              <p class="text-[12.5px] text-[#9A7F84] tracking-[.05em]">{m.crm}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
