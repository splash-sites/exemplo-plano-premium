---
import Layout from '../layouts/Layout.astro';
import { seo, testimonials, waDefault, img } from '../data/content';
---
<Layout title={seo.depoimentos.title} description={seo.depoimentos.description} path="/depoimentos" ogImage={img.faceHero}>

  <section class="max-w-[900px] mx-auto px-6 md:px-8 pt-20 pb-8 text-center" data-aos="fade-up">
    <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Depoimentos</span>
    <h1 class="font-serif text-4xl md:text-[46px] text-dark mt-4 mb-5 leading-[1.15]">O que dizem nossas pacientes</h1>
    <p class="text-[15px] leading-[1.7] text-muted">Relatos compartilhados com autorização. Alguns nomes foram abreviados por privacidade.</p>
  </section>

  <section class="max-w-[1000px] mx-auto px-6 md:px-8 py-10 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
      {testimonials.map((d, i) => (
        <div class="bg-white border border-bordercol rounded-2xl p-8" data-aos="fade-up" data-aos-delay={i * 60}>
          <svg width="28" height="22" viewBox="0 0 26 20" fill="#E7B9C2" class="mb-4"><path d="M0 20V11C0 4.9 3.6 1 9.4 0l1 3.1C6.9 4 5.2 5.6 5 8h4v12H0zm15 0V11C15 4.9 18.6 1 24.4 0l1 3.1C21.9 4 20.2 5.6 20 8h4v12h-9z"></path></svg>
          <p class="text-[15px] leading-[1.75] text-[#5A4747] mb-5.5">{d.text}</p>
          <p class="text-[13.5px] text-primary font-medium">{d.name}<span class="text-[#9A7F84] font-normal"> · {d.treatment}</span></p>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-8 py-3.5 rounded-full text-[14.5px] font-medium hover:bg-dark transition-colors inline-block">Agende sua avaliação</a>
    </div>
  </section>

</Layout>
