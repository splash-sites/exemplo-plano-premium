---
import Layout from '../layouts/Layout.astro';
import { site, seo, waDefault, treatments, cases, testimonials, img } from '../data/content';

const casesPreview = cases.slice(0, 3);
const testimonialsPreview = testimonials.slice(0, 3);
---
<Layout title={seo.home.title} description={seo.home.description} path="/" ogImage={img.faceHero}>

  <section class="bg-blush overflow-hidden">
    <div class="max-w-[1180px] mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-12 md:gap-16 items-center min-h-[560px]">
      <div class="py-16 md:py-20">
        <div class="flex items-center gap-2.5 mb-6" data-aos="fade-up">
          <div class="w-6 h-px bg-primary"></div>
          <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Torres · Rio Grande do Sul</span>
        </div>
        <h1 class="font-serif font-normal text-4xl md:text-5xl lg:text-[56px] leading-[1.1] text-dark mb-6 animate-fade-in-up">
          Realce a sua beleza natural, no seu tempo.
        </h1>
        <p class="text-[17px] leading-[1.7] text-muted max-w-[440px] mb-9 animate-fade-in" style="animation-delay:.3s">
          Uma clínica dedicada a procedimentos estéticos avançados com critério médico, produtos registrados e um cuidado atento a cada detalhe do seu rosto.
        </p>
        <div class="flex items-center gap-6 flex-wrap" data-aos="fade-up" data-aos-delay="150">
          <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-8 py-4 rounded-full text-[15px] font-medium hover:scale-105 hover:bg-dark transition-all inline-block">
            Agende sua avaliação
          </a>
          <a href="/servicos" class="text-[15px] text-primary border-b border-[#D9AEB6] pb-1">Conheça os tratamentos</a>
        </div>
      </div>
      <div class="self-stretch relative hidden md:block">
        <div class="absolute inset-0 top-12">
          <img src={img.faceHero} width="1600" height="900" fetchpriority="high" alt={`${site.nome} — ${site.nicho} em ${site.cidade}`} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 pt-24 pb-8">
    <div class="text-center mb-14" data-aos="fade-up">
      <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Nossos tratamentos</span>
      <h2 class="font-serif text-3xl md:text-[38px] text-dark mt-3">Cuidado especializado, resultado natural</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {treatments.map((t, i) => (
        <a href={`/servicos#${t.anchor}`} class="group flex flex-col bg-white border border-bordercol rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="h-[180px] overflow-hidden">
            <img src={t.img} width="600" height="180" loading="lazy" alt={t.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <div class="w-8 h-0.5 bg-secondary mb-3"></div>
            <h3 class="font-serif font-medium text-xl text-dark mb-2">{t.name}</h3>
            <p class="text-[13.5px] leading-relaxed text-softmuted">{t.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 py-20">
    <div class="flex items-end justify-between mb-10 flex-wrap gap-4" data-aos="fade-up">
      <div>
        <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Resultados reais</span>
        <h2 class="font-serif text-2xl md:text-[34px] text-dark mt-3">Antes e depois</h2>
      </div>
      <a href="/antes-depois" class="text-sm text-primary border-b border-[#D9AEB6] pb-1">Ver galeria completa</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {casesPreview.map((c, i) => (
        <div class="bg-white border border-bordercol rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay={i * 80}>
          <div class="grid grid-cols-2 gap-0.5 h-[200px]">
            <div class="relative overflow-hidden">
              <img src={c.imgA} width="300" height="200" loading="lazy" alt={`${c.treatment} — antes`} class="w-full h-full object-cover" />
              <span class="absolute top-2.5 left-2.5 bg-dark/80 text-cream text-[10px] tracking-[.12em] uppercase px-2.5 py-1 rounded-full">Antes</span>
            </div>
            <div class="relative overflow-hidden">
              <img src={c.imgB} width="300" height="200" loading="lazy" alt={`${c.treatment} — depois`} class="w-full h-full object-cover" />
              <span class="absolute top-2.5 left-2.5 bg-primary/90 text-cream text-[10px] tracking-[.12em] uppercase px-2.5 py-1 rounded-full">Depois</span>
            </div>
          </div>
          <div class="px-4.5 py-4"><p class="text-[13px] text-softmuted">{c.caption}</p></div>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-[1180px] mx-auto px-6 md:px-8 pb-20">
    <div class="bg-dark rounded-[20px] overflow-hidden grid md:grid-cols-[1.2fr_1fr] items-center" data-aos="fade-up">
      <div class="p-10 md:p-14">
        <span class="text-[11.5px] tracking-[.24em] uppercase text-secondary">Campanha em destaque</span>
        <h2 class="font-serif text-3xl md:text-[34px] text-cream mt-3.5 mb-4 leading-tight">Preenchimento labial com condição especial</h2>
        <a href="/campanha" class="bg-cream text-dark px-7 py-3.5 rounded-full text-sm font-medium inline-block hover:bg-secondary transition-colors">Ver a campanha</a>
      </div>
      <div class="self-stretch min-h-[280px]">
        <img src={img.lipsWide} width="1200" height="500" loading="lazy" alt="Close de lábios com iluminação suave" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-blush">
    <div class="max-w-[1180px] mx-auto px-6 md:px-8 py-24">
      <div class="text-center mb-12" data-aos="fade-up">
        <span class="text-[11.5px] tracking-[.24em] uppercase text-primary">Quem já cuidou aqui</span>
        <h2 class="font-serif text-2xl md:text-[34px] text-dark mt-3">Depoimentos</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-11">
        {testimonialsPreview.map((d, i) => (
          <div class="bg-white border border-bordercol rounded-2xl p-7" data-aos="fade-up" data-aos-delay={i * 80}>
            <svg width="26" height="20" viewBox="0 0 26 20" fill="#E7B9C2" class="mb-3.5"><path d="M0 20V11C0 4.9 3.6 1 9.4 0l1 3.1C6.9 4 5.2 5.6 5 8h4v12H0zm15 0V11C15 4.9 18.6 1 24.4 0l1 3.1C21.9 4 20.2 5.6 20 8h4v12h-9z"></path></svg>
            <p class="text-[14.5px] leading-relaxed text-[#5A4747] mb-5">{d.text}</p>
            <p class="text-[13px] text-primary font-medium">{d.name}<span class="text-[#9A7F84] font-normal"> · {d.treatment}</span></p>
          </div>
        ))}
      </div>
      <div class="text-center"><a href="/depoimentos" class="text-sm text-primary border-b border-[#D9AEB6] pb-1">Ler todos os depoimentos</a></div>
    </div>
  </section>

  <section class="max-w-[900px] mx-auto px-6 md:px-8 py-24 text-center" data-aos="zoom-in">
    <svg width="26" height="32" viewBox="0 0 24 30" fill="none" stroke="#C99CA6" stroke-width="1" stroke-linecap="round" class="mx-auto mb-5">
      <path d="M12 29 C12 20 12 11 12 2"></path><path d="M12 22 C7 20.5 5 16.5 5 12.5"></path><path d="M12 22 C17 20.5 19 16.5 19 12.5"></path><path d="M12 15 C8.5 13.8 6.5 11 6.5 8"></path><path d="M12 15 C15.5 13.8 17.5 11 17.5 8"></path><circle cx="12" cy="2.6" r="1.7" fill="#C99CA6" stroke="none"></circle>
    </svg>
    <h2 class="font-serif text-3xl md:text-4xl text-dark mb-5 leading-tight">Vamos conversar sobre o que faz sentido para você?</h2>
    <p class="text-base text-muted mb-8 max-w-[520px] mx-auto">Toda jornada começa com uma avaliação individual, sem compromisso, para entender seus objetivos com clareza.</p>
    <a href={waDefault} target="_blank" rel="noopener" class="bg-primary text-cream px-8 py-4 rounded-full text-[15px] font-medium hover:bg-dark transition-colors inline-block">Agende sua avaliação</a>
  </section>

</Layout>
